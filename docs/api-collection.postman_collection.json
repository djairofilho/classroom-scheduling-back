{
  "info": {
    "_postman_id": "f90b4a33-c746-4a22-a3eb-0e7b99d1f067",
    "name": "Classroom Scheduler API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "salaId",
      "value": "1"
    },
    {
      "key": "usuarioId",
      "value": "1"
    },
    {
      "key": "reservaId",
      "value": "1"
    },
    {
      "key": "manutencaoId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Salas",
      "item": [
        {
          "name": "Listar salas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/salas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "salas"
              ]
            }
          }
        },
        {
          "name": "Listar salas disponiveis",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/salas/disponiveis?inicio=2026-05-10T10:00:00&fim=2026-05-10T12:00:00&capacidadeMinima=30",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "salas",
                "disponiveis"
              ],
              "query": [
                {
                  "key": "inicio",
                  "value": "2026-05-10T10:00:00"
                },
                {
                  "key": "fim",
                  "value": "2026-05-10T12:00:00"
                },
                {
                  "key": "capacidadeMinima",
                  "value": "30"
                }
              ]
            }
          }
        },
        {
          "name": "Criar sala",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Sala B201\",\n  \"capacidade\": 40,\n  \"predioId\": 1,\n  \"recursoIds\": [1, 2]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/salas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "salas"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reservas",
      "item": [
        {
          "name": "Criar reserva",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": {{usuarioId}},\n  \"salaId\": {{salaId}},\n  \"inicio\": \"2026-05-10T10:00:00\",\n  \"fim\": \"2026-05-10T12:00:00\",\n  \"motivo\": \"Estudo em grupo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reservas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservas"
              ]
            }
          }
        },
        {
          "name": "Listar minhas reservas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reservas/minhas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservas",
                "minhas"
              ]
            }
          }
        },
        {
          "name": "Cancelar reserva",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/reservas/{{reservaId}}/cancelar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservas",
                "{{reservaId}}",
                "cancelar"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Manutencoes",
      "item": [
        {
          "name": "Criar manutencao",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inicio\": \"2026-05-11T08:00:00\",\n  \"fim\": \"2026-05-11T18:00:00\",\n  \"motivo\": \"Manutencao do projetor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/salas/{{salaId}}/manutencoes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "salas",
                "{{salaId}}",
                "manutencoes"
              ]
            }
          }
        },
        {
          "name": "Remover manutencao",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/salas/{{salaId}}/manutencoes/{{manutencaoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "salas",
                "{{salaId}}",
                "manutencoes",
                "{{manutencaoId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
